# ── Sanity (CMS) ──────────────────────────────────────────────────────────────
# Create project at sanity.io/manage, then paste values here
NEXT_PUBLIC_SANITY_PROJECT_ID=your-project-id
NEXT_PUBLIC_SANITY_DATASET=production
# For on-demand revalidation (create a random string)
SANITY_REVALIDATE_SECRET=your-random-secret-here

# ── Stripe ────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Resend (email) ────────────────────────────────────────────────────────────
# Get free API key at resend.com — 3,000 emails/month free
RESEND_API_KEY=re_...
# The "from" address — must match a domain you've verified in Resend
EMAIL_FROM=orders@patagoniamade.com
# Where ops/fulfillment alerts go
EMAIL_OPS=hola@patagoniamade.com

# ── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000
